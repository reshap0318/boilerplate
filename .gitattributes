# Set default behavior to automatic normalization
* text=auto

# Explicitly declare text files you want to always be normalized
*.go text eol=lf
*.md text eol=lf
*.toml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.mod text eol=lf
*.sum text eol=lf
*.sh text eol=lf
*.txt text eol=l

# Denote all files that are truly binary and should not be modified
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary